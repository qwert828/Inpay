<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Merchant Dashboard - InPay</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#060910;color:#e8edf5;font-family:Arial,sans-serif;min-height:100vh}
.nav{background:#0f1520;border-bottom:1px solid #1a2235;padding:16px 24px;display:flex;justify-content:space-between;align-items:center}
.logo{font-size:20px;font-weight:800;color:#00d9a3;text-decoration:none}
.nav-right{display:flex;align-items:center;gap:16px}
.merchant-name{font-size:13px;color:#5a6a85}
.logout{font-size:12px;color:#5a6a85;text-decoration:none;padding:6px 12px;border:1px solid #1a2235;border-radius:6px}
.container{padding:24px;max-width:1000px;margin:0 auto}
.welcome{margin-bottom:32px}
.welcome h1{font-size:24px;font-weight:700;margin-bottom:4px}
.welcome p{color:#5a6a85;font-size:14px}
.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:32px}
.stat-card{background:#0f1520;border:1px solid #1a2235;border-radius:12px;padding:20px}
.stat-card .label{font-size:12px;color:#5a6a85;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.stat-card .value{font-size:28px;font-weight:700;color:#e8edf5}
.stat-card .change{font-size:12px;color:#00d9a3;margin-top:4px}
.section{background:#0f1520;border:1px solid #1a2235;border-radius:12px;padding:20px;margin-bottom:24px}
.section-title{font-size:16px;font-weight:700;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center}
.btn{background:#00d9a3;color:#060910;padding:8px 16px;border-radius:8px;text-decoration:none;font-weight:700;font-size:13px;border:none;cursor:pointer}
.btn-sm{padding:6px 12px;font-size:12px}
.qr-box{background:#060910;border:2px dashed rgba(0,217,163,.3);border-radius:12px;padding:32px;text-align:center;margin-bottom:16px}
.qr-placeholder{width:120px;height:120px;background:rgba(0,217,163,.1);border:2px solid rgba(0,217,163,.3);border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:40px}
.qr-url{font-family:monospace;font-size:11px;color:#00d9a3;background:#0f1520;padding:8px 12px;border-radius:6px;word-break:break-all}
.tx-list{display:flex;flex-direction:column;gap:8px}
.tx-item{display:flex;justify-content:space-between;align-items:center;padding:12px;background:#060910;border-radius:8px}
.tx-left .tx-ref{font-size:13px;font-weight:600}
.tx-left .tx-time{font-size:11px;color:#5a6a85;margin-top:2px}
.tx-right .tx-amount{font-size:14px;font-weight:700;color:#00d9a3}
.tx-right .tx-status{font-size:11px;color:#5a6a85;text-align:right;margin-top:2px}
.badge{display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700}
.badge-success{background:rgba(0,217,163,.1);color:#00d9a3}
.badge-pending{background:rgba(245,158,11,.1);color:#f59e0b}
.badge-failed{background:rgba(239,68,68,.1);color:#ef4444}
.network-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.network-item{background:#060910;border-radius:8px;padding:12px;display:flex;align-items:center;gap:10px}
.network-dot{width:8px;height:8px;border-radius:50%}
.network-name{font-size:13px;font-weight:600}
.network-pct{font-size:12px;color:#5a6a85;margin-left:auto}
.api-key-box{background:#060910;border:1px solid rgba(0,217,163,.2);border-radius:8px;padding:12px;font-family:monospace;font-size:11px;color:#00d9a3;word-break:break-all;margin-bottom:12px}
.copy-btn{background:transparent;border:1px solid #1a2235;color:#5a6a85;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-family:Arial}
.copy-btn:hover{border-color:#00d9a3;color:#00d9a3}
.empty{text-align:center;padding:32px;color:#5a6a85;font-size:14px}
</style>
</head>
<body>

<div class="nav">
<a href="/" class="logo">InPay</a>
<div class="nav-right">
<span class="merchant-name" id="merchant-name">My Business</span>
<a href="/" class="logout">Sign Out</a>
</div>
</div>

<div class="container">

<div class="welcome">
<h1>Welcome back, <span id="welcome-name">Merchant</span></h1>
<p>Here is your InPay dashboard for today</p>
</div>

<div class="stats-grid">
<div class="stat-card">
<div class="label">Today's Revenue</div>
<div class="value" id="today-rev">ZMW 0.00</div>
<div class="change">0 transactions today</div>
</div>
<div class="stat-card">
<div class="label">This Month</div>
<div class="value" id="month-rev">ZMW 0.00</div>
<div class="change">Getting started</div>
</div>
<div class="stat-card">
<div class="label">Total Transactions</div>
<div class="value" id="total-tx">0</div>
<div class="change">Since joining InPay</div>
</div>
<div class="stat-card">
<div class="label">Success Rate</div>
<div class="value">—</div>
<div class="change">No transactions yet</div>
</div>
</div>

<div class="section">
<div class="section-title">
Your InPay QR Code
<button class="btn btn-sm" onclick="downloadQR()">Download QR</button>
</div>
<div class="qr-box">
<div class="qr-placeholder">📱</div>
<p style="color:#5a6a85;font-size:13px;margin-bottom:12px">Your merchants QR code will appear here once your account is approved. Share it with customers to accept payments from all 5 networks.</p>
<div class="qr-url" id="qr-url">pay.inpay.zm/q/pending-approval</div>
</div>
<p style="font-size:12px;color:#5a6a85">Customers scan this QR with any mobile money app to pay you instantly.</p>
</div>

<div class="section">
<div class="section-title">Recent Transactions</div>
<div class="empty" id="tx-empty">
No transactions yet. Share your QR code to start accepting payments.
</div>
<div class="tx-list" id="tx-list" style="display:none"></div>
</div>

<div class="section">
<div class="section-title">Payments by Network</div>
<div class="network-grid">
<div class="network-item"><div class="network-dot" style="background:#ffcb00"></div><div class="network-name">MTN</div><div class="network-pct">—</div></div>
<div class="network-item"><div class="network-dot" style="background:#ff6b6b"></div><div class="network-name">Airtel</div><div class="network-pct">—</div></div>
<div class="network-item"><div class="network-dot" style="background:#00d4ff"></div><div class="network-name">Zamtel</div><div class="network-pct">—</div></div>
<div class="network-item"><div class="network-dot" style="background:#a78bfa"></div><div class="network-name">SpeedPay</div><div class="network-pct">—</div></div>
<div class="network-item"><div class="network-dot" style="background:#22c55e"></div><div class="network-name">ZedMobile</div><div class="network-pct">—</div></div>
</div>
</div>

<div class="section">
<div class="section-title">Your API Key</div>
<div class="api-key-box" id="api-key">inpay_sandbox_••••••••••••••••••••••••••••••</div>
<div style="display:flex;gap:8px">
<button class="copy-btn" onclick="copyKey()">Copy API Key</button>
<a href="/docs.html" class="copy-btn" style="text-decoration:none">View API Docs</a>
</div>
</div>

<div class="section">
<div class="section-title">Account Status</div>
<div style="display:flex;flex-direction:column;gap:12px">
<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#060910;border-radius:8px">
<span style="font-size:13px">Sandbox API Key</span>
<span class="badge badge-success">Active</span>
</div>
<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#060910;border-radius:8px">
<span style="font-size:13px">KYB Verification</span>
<span class="badge badge-pending">Pending</span>
</div>
<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#060910;border-radius:8px">
<span style="font-size:13px">Live API Key</span>
<span class="badge badge-pending">Pending KYB</span>
</div>
<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#060910;border-radius:8px">
<span style="font-size:13px">BOZ Compliance</span>
<span class="badge badge-pending">In Progress</span>
</div>
</div>
</div>

</div>

<script>
const params = new URLSearchParams(window.location.search);
const name = params.get('name') || localStorage.getItem('inpay_merchant_name') || 'Merchant';
const key = params.get('key') || localStorage.getItem('inpay_api_key') || 'inpay_sandbox_demo';

document.getElementById('merchant-name').textContent = name;
document.getElementById('welcome-name').textContent = name;
document.getElementById('api-key').textContent = key;
document.getElementById('qr-url').textContent = 'pay.inpay.zm/q/' + key.slice(-8);

if(params.get('name')) localStorage.setItem('inpay_merchant_name', params.get('name'));
if(params.get('key')) localStorage.setItem('inpay_api_key', params.get('key'));

function copyKey(){
navigator.clipboard.writeText(document.getElementById('api-key').textContent);
alert('API key copied!');
}

function downloadQR(){
alert('QR download will be available once your account is approved.');
}
</script>
</body>
</html>
