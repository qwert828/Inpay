
!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Sign Up - InPay</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#060910;color:#e8edf5;font-family:Arial,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
.card{background:#0f1520;border:1px solid #1a2235;border-radius:16px;padding:40px;width:100%;max-width:420px}
.logo{font-size:28px;font-weight:800;color:#00d9a3;text-align:center;margin-bottom:8px}
.subtitle{color:#5a6a85;font-size:14px;text-align:center;margin-bottom:32px}
h2{font-size:20px;font-weight:700;margin-bottom:24px;text-align:center}
.field{margin-bottom:16px}
.field label{display:block;font-size:12px;color:#5a6a85;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;font-weight:600}
.field input,.field select{width:100%;background:#060910;border:1px solid #1a2235;border-radius:8px;padding:12px 14px;color:#e8edf5;font-size:14px;font-family:Arial,sans-serif;outline:none}
.field input:focus,.field select:focus{border-color:#00d9a3}
.field input::placeholder{color:#5a6a85}
.field select option{background:#0f1520}
.btn{width:100%;background:#00d9a3;color:#060910;border:none;border-radius:8px;padding:13px;font-size:15px;font-weight:700;cursor:pointer;margin-top:8px;font-family:Arial,sans-serif}
.btn:hover{background:#00a87e}
.login-link{text-align:center;margin-top:20px;font-size:13px;color:#5a6a85}
.login-link a{color:#00d9a3;text-decoration:none}
.success{display:none;text-align:center;padding:20px 0}
.success h3{color:#00d9a3;font-size:20px;margin-bottom:12px}
.success p{color:#5a6a85;font-size:14px;line-height:1.6}
.api-key{background:#060910;border:1px solid rgba(0,217,163,.3);border-radius:8px;padding:12px;font-family:monospace;font-size:11px;color:#00d9a3;word-break:break-all;margin:16px 0;text-align:left}
.back{display:inline-block;color:#5a6a85;text-decoration:none;font-size:13px;margin-bottom:20px}
.back:hover{color:#00d9a3}
</style>
</head>
<body>
<div class="card">
<a href="/" class="back">← Back to InPay</a>
<div class="logo">InPay</div>
<div class="subtitle">Zambia's Unified Payment Rail</div>

<div id="form-section">
<h2>Create Merchant Account</h2>
<div class="field"><label>Business Name</label><input type="text" id="bname" placeholder="e.g. Acme Shop Lusaka"></div>
<div class="field"><label>Email Address</label><input type="email" id="email" placeholder="you@business.zm"></div>
<div class="field"><label>Phone Number</label><input type="text" id="phone" placeholder="+260 97X XXX XXX"></div>
<div class="field"><label>Province</label>
<select id="province">
<option value="">Select province...</option>
<option>Lusaka</option><option>Copperbelt</option><option>Central</option>
<option>Eastern</option><option>Luapula</option><option>Muchinga</option>
<option>Northern</option><option>North-Western</option><option>Southern</option><option>Western</option>
</select></div>
<div class="field"><label>Business Type</label>
<select id="btype">
<option value="">Select type...</option>
<option>Retail Shop</option><option>Restaurant / Cafe</option><option>Supermarket</option>
<option>Professional Services</option><option>Online / E-Commerce</option>
<option>Healthcare</option><option>Education</option><option>NGO / Non-Profit</option><option>Other</option>
</select></div>
<button class="btn" onclick="signup()">Create Account and Get API Key</button>
<div class="login-link">Already have an account? <a href="/admin/index.html">Sign in</a></div>
</div>

<div class="success" id="success-section">
<h3>Welcome to InPay!</h3>
<p>Your sandbox API key is ready. Save it now — it will not be shown again.</p>
<div class="api-key" id="api-key-display"></div>
<p style="font-size:12px;color:#5a6a85;margin-bottom:20px">Your live key will be issued after KYB verification.</p>
<a href="/docs.html" class="btn" style="display:block;text-align:center;text-decoration:none">View API Documentation</a>
</div>
</div>

<script>
function signup() {
  const bname = document.getElementById('bname').value.trim();
  const email = document.getElementById('email').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const province = document.getElementById('province').value;
  const btype = document.getElementById('btype').value;
  if (!bname || !email || !phone || !province || !btype) {
    alert('Please fill in all fields');
    return;
  }
  const key = 'inpay_sandbox_' + Array.from(crypto.getRandomValues(new Uint8Array(20))).map(b=>b.toString(16).padStart(2,'0')).join('');
  document.getElementById('api-key-display').textContent = key;
  document.getElementById('form-section').style.display = 'none';
  document.getElementById('success-section').style.display = 'block';
}
</script>
</body>
</html>
